OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
AI_ENABLED=false
AI_CONFIDENCE_THRESHOLD=0.75
AI_MAX_ROWS=80
AI_CONCURRENCY=4
# Per-call timeout. Reasoning models (gpt-5*) need more than 25s even at low effort.
AI_REQUEST_TIMEOUT_MS=45000
# Max AI-rescue chunks per ledger (90 lines each).
AI_RESCUE_MAX_CHUNKS=60
# Total wall-clock the whole run may spend on AI calls. Must stay well inside the
# hosting proxy's request timeout or the browser sees "upstream error".
AI_TIME_BUDGET_MS=210000
